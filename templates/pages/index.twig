{% extends 'layouts/landing.twig' %}

{% block content %}
  {# ── Hero ── #}
  <section class="landing-hero">
    <div class="landing-hero-inner">
      <h1 class="landing-title">{{ page.title }}</h1>
      <p class="landing-tagline">{{ page.excerpt }}</p>
      <div class="landing-actions">
        <a class="landing-btn landing-btn--primary" href="{{ url('/updates') }}">
          Erste Schritte
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a class="landing-btn landing-btn--secondary" href="https://github.com/atoll-cms" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </section>

  {# ── Features ── #}
  <section class="landing-features">
    <div class="landing-features-inner">
      <div class="landing-feature">
        <div class="landing-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3>Zero JS by default</h3>
        <p>Statisches HTML wird direkt ausgeliefert. Interaktivitaet nur als Island bei Bedarf.</p>
      </div>
      <div class="landing-feature">
        <div class="landing-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Shared Hosting ready</h3>
        <p>PHP 8.2+, kein Node, kein Build-Step. Laeuft ueberall.</p>
      </div>
      <div class="landing-feature">
        <div class="landing-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Sicher &amp; schlank</h3>
        <p>Flat-File, CSRF-Schutz, Rate-Limiting, 2FA — alles eingebaut.</p>
      </div>
    </div>
  </section>

  {# ── Docs Grid ── #}
  <section class="landing-docs">
    <div class="landing-docs-inner">
      <h2>Dokumentation</h2>
      <div class="landing-docs-grid">
        <a class="feature-card" href="{{ url('/updates') }}">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6"/><path d="M2.5 22v-6h6"/><path d="M2 11.5a10 10 0 0 1 18.8-4.3"/><path d="M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
          </div>
          <h3>Updates</h3>
          <p>Signierte Releases, Migrations und Rollback-Strategien.</p>
        </a>
        <a class="feature-card" href="{{ url('/plugins') }}">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4l-9-5.19"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <h3>Plugins</h3>
          <p>Installieren, aktivieren und eigene Pakete bereitstellen.</p>
        </a>
        <a class="feature-card" href="{{ url('/themes') }}">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12a10 10 0 0 0 5.338 8.87"/><path d="M8 22a4 4 0 0 0 4-4v-2"/></svg>
          </div>
          <h3>Themes</h3>
          <p>Overrides, Assets und visuelle Anpassungen pro Projekt.</p>
        </a>
        <a class="feature-card" href="{{ url('/demo') }}">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 20h8"/><path d="M12 18v2"/><path d="m10 10 2 1.5 2-1.5"/></svg>
          </div>
          <h3>Live Demo</h3>
          <p>Deployment flow und oeffentliche Demo-Instanz von atoll-starter.</p>
        </a>
      </div>
    </div>
  </section>
{% endblock %}
