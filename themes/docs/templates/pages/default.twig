{% extends 'layouts/base.twig' %}

{% block content %}
  <section class="hero hero-docs">
    <p class="eyebrow">Dokumentation</p>
    <h1>{{ page.title }}</h1>
    {% if page.excerpt %}
      <p class="hero-copy">{{ page.excerpt }}</p>
    {% endif %}
  </section>

  <article class="prose doc-prose">
    {{ page.content|raw }}
  </article>
{% endblock %}
