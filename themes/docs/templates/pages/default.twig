{% extends 'layouts/base.twig' %}

{% block content %}
  <section class="hero hero-compact">
    {% if page.eyebrow is defined %}<p class="eyebrow">{{ page.eyebrow }}</p>{% endif %}
    <h1>{{ page.title }}</h1>
    {% if page.excerpt %}
      <p class="hero-copy">{{ page.excerpt }}</p>
    {% endif %}
  </section>

  <article class="prose doc-prose">
    {{ page.content|raw }}
  </article>
{% endblock %}
